#!/bin/bash
set -uo pipefail

GIT_HOST="github.com"

REPOS=(
  "$HOME/dotfiles"$'\t'"chantastic/dotfiles"
  "$HOME/Sites"$'\t'"chantastic/sites"
  "$HOME/.agents"$'\t'"chantastic/agents"
  "$HOME/.config"$'\t'"chantastic/config"
  "$HOME/.pi"$'\t'"chantastic/pi"
)

log() {
  printf '%s\n' "$*"
}

normalize_repo() {
  local repo="$1"

  repo="${repo%/}"
  repo="${repo%.git}"

  case "$repo" in
    *://*)
      repo="${repo#*://}"
      repo="${repo#*@}"
      repo="${repo#${GIT_HOST}/}"
      ;;
    *@*:*)
      repo="${repo#*@}"
      repo="${repo#${GIT_HOST}:}"
      ;;
    "$GIT_HOST"/*)
      repo="${repo#${GIT_HOST}/}"
      ;;
  esac

  printf '%s\n' "$repo"
}

clone_url() {
  printf 'git@%s:%s.git\n' "$GIT_HOST" "$1"
}

sync_repo() {
  local target="$1"
  local expected_repo="$2"
  local actual_url actual_repo status_output branch upstream counts behind ahead

  if [[ ! -e "$target" ]]; then
    mkdir -p "$(dirname "$target")" || return
    if git clone --quiet "$(clone_url "$expected_repo")" "$target"; then
      log "[CLONED] $target"
    else
      log "[ERROR] clone failed for $target"
    fi
    return
  fi

  if [[ ! -d "$target/.git" ]]; then
    log "[SKIP] $target exists but is not a git repo"
    return
  fi

  actual_url="$(git -C "$target" remote get-url origin 2>/dev/null || true)"
  if [[ -z "$actual_url" ]]; then
    log "[NO ORIGIN] $target"
    return
  fi

  actual_repo="$(normalize_repo "$actual_url")"
  if [[ "$actual_repo" != "$expected_repo" ]]; then
    log "[REMOTE MISMATCH] $target (origin: $actual_url, expected: $expected_repo)"
    return
  fi

  if ! git -C "$target" fetch --prune --quiet origin; then
    log "[ERROR] $target fetch failed"
    return
  fi

  status_output="$(git -C "$target" status --porcelain --untracked-files=normal 2>/dev/null)" || {
    log "[ERROR] $target git status failed"
    return
  }

  if [[ -n "$status_output" ]]; then
    log "[DIRTY] $target"
    return
  fi

  branch="$(git -C "$target" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  if [[ -z "$branch" ]]; then
    log "[DETACHED] $target"
    return
  fi

  upstream="$(git -C "$target" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"
  if [[ -z "$upstream" ]]; then
    log "[NO UPSTREAM] $target ($branch)"
    return
  fi

  counts="$(git -C "$target" rev-list --left-right --count "${upstream}...HEAD" 2>/dev/null || true)"
  if [[ -z "$counts" ]]; then
    log "[ERROR] $target could not compare against $upstream"
    return
  fi

  read -r behind ahead <<<"$counts"

  if [[ "$behind" -gt 0 && "$ahead" -gt 0 ]]; then
    log "[DIVERGED] $target ($branch: ahead $ahead, behind $behind)"
  elif [[ "$behind" -gt 0 ]]; then
    log "[BEHIND] $target ($branch: behind $behind)"
  elif [[ "$ahead" -gt 0 ]]; then
    if git -C "$target" push --quiet; then
      log "[PUSHED] $target ($branch -> $upstream, $ahead commit(s))"
    else
      log "[ERROR] $target push failed"
    fi
  else
    log "[OK] $target"
  fi
}

for entry in "${REPOS[@]}"; do
  IFS=$'\t' read -r target repo <<<"$entry"
  sync_repo "$target" "$(normalize_repo "$repo")"
done
